import pandas as pd
import json
import numpy as np
from sentence_transformers import SentenceTransformer

# Load JSONL
data = []
with open("../data/raw/news_articles.jsonl", "r") as f:
    for line in f:
        data.append(json.loads(line))

df = pd.DataFrame(data)

# Load Model
model = SentenceTransformer('sentence-transformers/all-MiniLM-L6-v2')

daily_embeddings = {}

# Group by Date
for date, group in df.groupby('date'):
    # Combine headline + first 200 chars of content for a dense representation
    texts = (group['headline'] + ": " + group['content'].str[:200]).tolist()
    
    # Encode and Average
    embeddings = model.encode(texts)
    daily_avg = np.mean(embeddings, axis=0)
    
    daily_embeddings[date] = daily_avg

# Save for RL Agent
emb_df = pd.DataFrame.from_dict(daily_embeddings, orient='index')
emb_df.to_csv("../data/raw/news_embeddings.csv")
print("✅ Daily embeddings saved!")
