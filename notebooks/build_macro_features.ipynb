import pandas as pd
import numpy as np

prices = pd.read_csv("/Users/aviralgarg/AI_Portfolio_Manager/data/raw/sp500_prices.csv", index_col=0, parse_dates=True)

dates = prices.index

# Example: 3 macro features (e.g., inflation, rates, VIX-like volatility proxy)
np.random.seed(0)
macro = pd.DataFrame(
    np.random.normal(size=(len(dates), 3)),
    index=dates,
    columns=["macro1", "macro2", "macro3"]
)

macro.to_csv("/Users/aviralgarg/AI_Portfolio_Manager/data/raw/macro_features.csv")
