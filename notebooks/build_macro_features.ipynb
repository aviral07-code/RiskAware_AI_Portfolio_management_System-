import pandas as pd
import numpy as np
import os

print("🧮 Calculating REAL Macro Features from Price Action...")

prices_path = "/Users/aviralgarg/AI_Portfolio_Manager/data/raw/sp500_prices.csv"
if not os.path.exists(prices_path):
    raise FileNotFoundError("Run the fetch_prices script first!")

prices = pd.read_csv(prices_path, index_col=0, parse_dates=True)
returns = prices.pct_change().fillna(0)
market_return = returns.mean(axis=1)

# Feature 1: Market Volatility (21-day rolling standard deviation annualized)
macro1_vol = market_return.rolling(window=21).std() * np.sqrt(252)

# Feature 2: Market Momentum (21-day cumulative market return)
macro2_mom = market_return.rolling(window=21).sum()

# Feature 3: Market Breadth (% of stocks trading above their 30-day moving average)
rolling_mean_30 = prices.rolling(window=30).mean()
breadth = (prices > rolling_mean_30).sum(axis=1) / prices.shape[1]

macro = pd.DataFrame({
    "Market_Volatility": macro1_vol,
    "Market_Momentum": macro2_mom,
    "Market_Breadth": breadth
}, index=prices.index)

# Forward fill and backward fill to clean up the NaN values generated by the rolling window
macro = macro.ffill().bfill().fillna(0)

out_path = "/Users/aviralgarg/AI_Portfolio_Manager/data/raw/macro_features.csv"
macro.to_csv(out_path)
print(f"✅ Real macro features generated and saved. Shape: {macro.shape}")
