import yfinance as yf
import pandas as pd

# Start with ~50 diversified large caps across sectors
tickers = [
    "AAPL","MSFT","AMZN","GOOGL","META","NVDA","TSLA","JPM","BAC","WFC",
    "XOM","CVX","COP","UNH","JNJ","PFE","MRK","PG","KO","PEP",
    "HD","LOW","DIS","NFLX","INTC","CSCO","ADBE","CRM","ORCL","AVGO",
    "V","MA","PYPL","C","GS","BLK","T","VZ","CMCSA","ABT",
    "COST","MCD","NKE","LIN","ACN","AMD","TXN","QCOM","HON","CAT"
]

data = yf.download(
    tickers,
    start="2018-01-01",
    end="2023-12-31",
    auto_adjust=True,
    interval="1d",
)

# Handle MultiIndex vs single index
if isinstance(data.columns, pd.MultiIndex):
    prices = data["Close"]
else:
    prices = data[["Close"]]

prices.to_csv("/Users/aviralgarg/AI_Portfolio_Manager/data/raw/sp500_prices.csv")
